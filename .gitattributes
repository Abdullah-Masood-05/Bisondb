# Enforce LF line endings for all source files to keep Windows/Linux diffs clean.

* text=auto

*.cpp    text eol=lf
*.hpp    text eol=lf
*.h      text eol=lf
*.c      text eol=lf
*.cmake  text eol=lf
CMakeLists.txt text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.txt    text eol=lf

# Binary
*.bson   binary
*.png    binary
*.jpg    binary
